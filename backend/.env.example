# PathFinder Environment Variables
# Copy this file to .env and fill in your values

# === REQUIRED ===
# Get it at: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# GitHub Personal Access Token
# Get it at: https://github.com/settings/tokens/new
# Required scopes: repo (read), user (read)
GITHUB_TOKEN=your_github_token_here


# Notion Integration Token
# Get it at: https://www.notion.so/my-integrations
# Create new integration -> copy "Internal Integration Token"
NOTION_TOKEN=your_notion_token_here

# === AUTO-FILLED BY SETUP SCRIPT ===
# Run: node scripts/setupNotion.js
NOTION_DATABASE_ID=your_notion_database_id_here

# === CONFIG ===
PORT=8080
FRONTEND_URL=http://localhost:5173

# === CORAL MODE (Optional) ===
# Set to 'true' if you install Coral CLI (WSL2 required on Windows)
# When false, app uses direct API calls (same data, no CLI needed)
CORAL_MODE=false
